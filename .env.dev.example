# Profile overrides for local development (dev).
# Select the profile by exporting APP_ENV in your shell (dev is the default):
#   APP_ENV=dev uv run uvicorn api.main:app --reload
# Copy to .env.dev (gitignored). Loaded after the base .env, so values here win.

SECRET_KEY=changeme
DATABASE_URL=sqlite:///./become.db
# Local SQLite uses create_all; Alembic targets PostgreSQL only. To migrate a
# remote database ad hoc, set ALEMBIC_DATABASE_URL when running alembic.
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
API_PUBLIC_URL=http://localhost:8000

# Photo storage is optional locally; attach a Railway bucket to enable uploads.
# BUCKET_NAME / BUCKET_ENDPOINT / BUCKET_ACCESS_KEY_ID / BUCKET_SECRET_ACCESS_KEY
